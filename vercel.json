{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none'" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "redirects": [
    { "source": "/products/concrete-drill/:slug", "destination": "/products", "permanent": true },
    { "source": "/products/step-drill/:slug", "destination": "/products", "permanent": true },
    { "source": "/products/hole-saw/bi", "destination": "/products/hole-saw/hss", "permanent": true },
    { "source": "/products/sds-plus", "destination": "/products", "permanent": true },
    { "source": "/products/hex-shank", "destination": "/products", "permanent": true }
  ]
}
